enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionStatus {
  PENDING
  QUEUED
  RUNNING
  PASSED
  FAILED
  ERROR
  TIMEOUT
}

enum SubmissionType {
  RUN
  SUBMIT
}

model Problem {
  id          String     @id @default(uuid())
  title       String
  description String
  constraints String?
  difficulty  Difficulty

  timeLimitMs Int @default(2000)

  testcases         TestCase[]
  battles           Battle[]
  teamBattleMatches TeamBattleMatch[]
  squidGameRounds   SquidGameRound[]
  contestProblems   ContestProblem[]

  updatedAt DateTime @default(now()) @updatedAt
  createdAt DateTime @default(now())

  submissions Submission[]
  tags        Tag[]
  hints       String[]
  userHints   UserHint[]
}

model Tag {
  id       String    @id @default(uuid())
  name     String    @unique
  problems Problem[]
}

model TestCase {
  id        String  @id @default(uuid())
  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String

  input  String
  output String

  isHidden Boolean @default(true)
  isSample Boolean @default(false)
}

model Submission {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  battle   Battle? @relation(fields: [battleId], references: [id])
  battleId String?

  squidGame   SquidGame? @relation(fields: [squidGameId], references: [id])
  squidGameId String?

  contest   Contest? @relation(fields: [contestId], references: [id])
  contestId String?

  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String

  code     String
  language String

  status SubmissionStatus @default(PENDING)

  passedTests Int?
  totalTests  Int?

  executionTimeMs Int?

  type SubmissionType @default(SUBMIT)

  aiFeedback String?

  createdAt DateTime @default(now())
}

model UserHint {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  problem   Problem  @relation(fields: [problemId], references: [id])
  problemId String
  hintIndex Int      // 0, 1, or 2
  
  battle    Battle?  @relation(fields: [battleId], references: [id])
  battleId  String?
  
  teamBattleMatch   TeamBattleMatch? @relation(fields: [teamBattleMatchId], references: [id])
  teamBattleMatchId String?

  unlockedAt DateTime @default(now())

  @@unique([userId, problemId, hintIndex, battleId, teamBattleMatchId])
}
