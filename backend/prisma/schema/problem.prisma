enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionStatus {
  PENDING
  QUEUED
  RUNNING
  PASSED
  FAILED
  ERROR
  TIMEOUT
}

enum SubmissionType {
  RUN
  SUBMIT
}

model Problem {
  id          String     @id @default(uuid())
  title       String
  description String
  constraints String?
  difficulty  Difficulty

  timeLimitMs Int @default(2000)

  testcases   TestCase[]
  battles     Battle[]
  teamBattleMatches TeamBattleMatch[]
  squidGameRounds SquidGameRound[]

  createdAt   DateTime @default(now())

  submissions Submission[]
}

model TestCase {
  id        String   @id @default(uuid())
  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String

  input     String
  output    String

  isHidden  Boolean @default(true)
  isSample  Boolean @default(false)
}

model Submission {
  id        String   @id @default(uuid())

  user      User   @relation(fields: [userId], references: [id])
  userId    String

  battle    Battle? @relation(fields: [battleId], references: [id])
  battleId  String?

  squidGame   SquidGame? @relation(fields: [squidGameId], references: [id])
  squidGameId String?

  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String
  
  code      String
  language  String

  status    SubmissionStatus @default(PENDING)

  passedTests Int?
  totalTests  Int?

  executionTimeMs Int?

  type      SubmissionType @default(SUBMIT)

  createdAt DateTime @default(now())
}
