enum Role {
  USER
  ADMIN
}

model User {
  id       String @id @default(uuid())
  username String @unique
  email    String @unique
  password String?
  role     Role   @default(USER)

  googleId String? @unique
  githubId String? @unique

  battlesAsPlayer1 Battle[] @relation("player1")
  battlesAsPlayer2 Battle[] @relation("player2")

  teamMemberships TeamMember[]
  teamsCreated    Team[]       @relation("creator")

  submissions           Submission[]
  teamBattleSubmissions TeamBattleSubmission[]

  teamBattleMatchesAsPlayer1 TeamBattleMatch[] @relation("match_player1")
  teamBattleMatchesAsPlayer2 TeamBattleMatch[] @relation("match_player2")

  // Team battles created by this user
  createdTeamBattles TeamBattle[] @relation("battleCreator")

  squidGameParticipants SquidGameParticipant[]
  hostedSquidGames      SquidGame[]

  createdContests      Contest[]
  participatedContests ContestParticipant[]
  rankPoints           Int                  @default(1000)
  wins                 Int                  @default(0)
  losses               Int                  @default(0)

  refreshTokenHash String?
  tokenVersion     Int       @default(0)
  failedLoginCount Int       @default(0)
  lockUntil        DateTime?

  // Social Relations
  followers        Follow[]        @relation("followers")
  following        Follow[]        @relation("following")
  sentRequests     FriendRequest[] @relation("sentRequests")
  receivedRequests FriendRequest[] @relation("receivedRequests")
  sentMessages     PrivateMessage[] @relation("sentMessages")
  receivedMessages PrivateMessage[] @relation("receivedMessages")

  // Profile Fields
  profilePic String?

  // Password Reset Fields
  resetPasswordToken String?
  resetPasswordExpires DateTime?
  linkedin   String?
  github     String?
  leetcode   String?
  gfg        String?
  hackerrank String?
  codeforces String?
  instagram  String?
  twitter    String?

  country    String?
  region     String?

  notifications Notification[]

  // Phase 4: Rewards & Achievements
  cyberCores       Int      @default(0)
  dailyLoginStreak Int      @default(0)
  lastLogin        DateTime @default(now())
  
  achievements     UserAchievement[]
  badges           UserBadge[]
  userHints        UserHint[]

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([refreshTokenHash]) // needed
}
