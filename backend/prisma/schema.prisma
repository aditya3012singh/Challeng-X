// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum BattleStatus {
  WAITING
  ONGOING
  FINISHED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionStatus {
  PENDING
  PASSED
  FAILED
  ERROR
  TIMEOUT
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(USER)

  battlesAsPlayer1 Battle[] @relation("player1")
  battlesAsPlayer2 Battle[] @relation("player2")

  teamMemberships TeamMember[]
  teamsCreated    Team[]       @relation("creator")

  submissions Submission[]
  teamBattleSubmissions TeamBattleSubmission[]

  rankPoints Int @default(1000)
  wins       Int @default(0)
  losses     Int @default(0)
  
  refreshTokenHash String?
  tokenVersion     Int      @default(0) 
  failedLoginCount Int      @default(0)
  lockUntil        DateTime?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([refreshTokenHash]) // needed
}

model Battle {
  id         String   @id @default(uuid())
  battleCode String   @unique // 6-digit code for easy sharing

  player1   User @relation("player1", fields: [player1Id], references: [id])
  player1Id String

  player2   User? @relation("player2", fields: [player2Id], references: [id])
  player2Id String?

  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String

  status    BattleStatus @default(WAITING)

  winnerId  String?

  startedAt DateTime?
  endedAt   DateTime?

  submissions Submission[]

  createdAt DateTime @default(now())
}

model Problem {
  id          String     @id @default(uuid())
  title       String
  description String
  difficulty  Difficulty

  timeLimitMs Int @default(2000)

  testcases   TestCase[]
  battles     Battle[]
  teamBattles TeamBattle[]

  createdAt   DateTime @default(now())

  submissions Submission[]
}

model TestCase {
  id        String   @id @default(uuid())
  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String

  input     String
  output    String

  isHidden  Boolean @default(true)
}

model Submission {
  id        String   @id @default(uuid())

  user      User   @relation(fields: [userId], references: [id])
  userId    String

  battle    Battle? @relation(fields: [battleId], references: [id])
  battleId  String?

  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String
  
  code      String
  language  String

  status    SubmissionStatus @default(PENDING)

  executionTimeMs Int?

  createdAt DateTime @default(now())
}

model Team {
  id        String   @id @default(uuid())
  name      String
  teamCode  String   @unique // 6-digit code for easy sharing

  creator   User @relation("creator", fields: [creatorId], references: [id])
  creatorId String

  members   TeamMember[]

  teamBattlesAsTeam1 TeamBattle[] @relation("team1")
  teamBattlesAsTeam2 TeamBattle[] @relation("team2")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String

  joinedAt DateTime @default(now())

  @@unique([userId, teamId])
}

model TeamBattle {
  id        String   @id @default(uuid())
  battleCode String  @unique

  team1   Team @relation("team1", fields: [team1Id], references: [id])
  team1Id String

  team2   Team? @relation("team2", fields: [team2Id], references: [id])
  team2Id String?

  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String

  maxTeamSize Int // 2, 3, 4, or 5
  status      BattleStatus @default(WAITING)
  currentRound Int @default(1)
  winnerTeamId String?

  submissions TeamBattleSubmission[]

  startedAt DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamBattleSubmission {
  id        String   @id @default(uuid())

  teamBattle   TeamBattle @relation(fields: [teamBattleId], references: [id], onDelete: Cascade)
  teamBattleId String

  submittedBy   User   @relation(fields: [submittedById], references: [id])
  submittedById String

  code     String
  language String
  output   String?

  status SubmissionStatus @default(PENDING)

  createdAt DateTime @default(now())
}
