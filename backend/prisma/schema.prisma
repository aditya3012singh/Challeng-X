// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum BattleStatus {
  WAITING
  ONGOING
  FINISHED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionStatus {
  PENDING
  QUEUED
  RUNNING
  PASSED
  FAILED
  ERROR
  TIMEOUT
}

enum SubmissionType {
  RUN
  SUBMIT
}

enum SquidGameStatus {
  REGISTRATION
  ROUND_ACTIVE
  ROUND_ENDED
  COMPLETED
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(USER)

  battlesAsPlayer1 Battle[] @relation("player1")
  battlesAsPlayer2 Battle[] @relation("player2")

  teamMemberships TeamMember[]
  teamsCreated    Team[]       @relation("creator")

  submissions Submission[]
  teamBattleSubmissions TeamBattleSubmission[]
  
  teamBattleMatchesAsPlayer1 TeamBattleMatch[] @relation("match_player1")
  teamBattleMatchesAsPlayer2 TeamBattleMatch[] @relation("match_player2")
  
  // Team battles created by this user
  createdTeamBattles TeamBattle[] @relation("battleCreator")

  squidGameParticipants SquidGameParticipant[]

  rankPoints Int @default(1000)
  wins       Int @default(0)
  losses     Int @default(0)
  
  refreshTokenHash String?
  tokenVersion     Int      @default(0) 
  failedLoginCount Int      @default(0)
  lockUntil        DateTime?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([refreshTokenHash]) // needed
}

model Battle {
  id         String   @id @default(uuid())
  battleCode String   @unique // 6-digit code for easy sharing

  player1   User @relation("player1", fields: [player1Id], references: [id])
  player1Id String

  player2   User? @relation("player2", fields: [player2Id], references: [id])
  player2Id String?

  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String

  status    BattleStatus @default(WAITING)

  winnerId  String?

  startedAt DateTime?
  endedAt   DateTime?

  submissions Submission[]

  attemptsPlayer1 Int @default(0)
  attemptsPlayer2 Int @default(0)

  createdAt DateTime @default(now())
}

model Problem {
  id          String     @id @default(uuid())
  title       String
  description String
  constraints String?
  difficulty  Difficulty

  timeLimitMs Int @default(2000)

  testcases   TestCase[]
  battles     Battle[]
  teamBattleMatches TeamBattleMatch[]
  squidGameRounds SquidGameRound[]

  createdAt   DateTime @default(now())

  submissions Submission[]
}

model TestCase {
  id        String   @id @default(uuid())
  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String

  input     String
  output    String

  isHidden  Boolean @default(true)
  isSample  Boolean @default(false)
}

model Submission {
  id        String   @id @default(uuid())

  user      User   @relation(fields: [userId], references: [id])
  userId    String

  battle    Battle? @relation(fields: [battleId], references: [id])
  battleId  String?

  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String
  
  code      String
  language  String

  status    SubmissionStatus @default(PENDING)

  passedTests Int?
  totalTests  Int?

  executionTimeMs Int?

  type      SubmissionType @default(SUBMIT)

  createdAt DateTime @default(now())
}

model Team {
  id        String   @id @default(uuid())
  name      String
  teamCode  String   @unique // 6-digit code for easy sharing

  creator   User @relation("creator", fields: [creatorId], references: [id])
  creatorId String

  members   TeamMember[]

  teamBattlesAsTeam1 TeamBattle[] @relation("team1")
  teamBattlesAsTeam2 TeamBattle[] @relation("team2")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String

  joinedAt DateTime @default(now())

  @@unique([userId, teamId])
}

model TeamBattle {
  id        String   @id @default(uuid())
  battleCode String  @unique
  joinCode  String   @unique // For Team2 to join

  // Team1: Creator of the battle
  team1   Team @relation("team1", fields: [team1Id], references: [id])
  team1Id String
  createdBy User @relation("battleCreator", fields: [createdByUserId], references: [id]) // Team1 leader
  createdByUserId String

  // Team2: Joins with code
  team2   Team? @relation("team2", fields: [team2Id], references: [id])
  team2Id String?
  joinedByUserId String? // First person from Team2 to join (for tracking)

  maxTeamSize Int // 2, 3, 4, or 5
  
  // Status: WAITING -> ONGOING -> FINISHED
  status      BattleStatus @default(WAITING)

  // Individual matches between paired team members
  matches TeamBattleMatch[]
  submissions TeamBattleSubmission[]

  team1Wins Int @default(0)
  team2Wins Int @default(0)
  winnerTeamId String?

  startedAt DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Individual 1v1 battle between paired team members
model TeamBattleMatch {
  id String @id @default(uuid())

  teamBattle   TeamBattle @relation(fields: [teamBattleId], references: [id], onDelete: Cascade)
  teamBattleId String

  // Team 1 player
  player1   User   @relation("match_player1", fields: [player1Id], references: [id])
  player1Id String

  // Team 2 player  
  player2   User   @relation("match_player2", fields: [player2Id], references: [id])
  player2Id String

  // Problem for this specific match
  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String

  player1Submission String?
  player2Submission String?

  player1Language String?
  player2Language String?

  player1Output String?
  player2Output String?

  status     BattleStatus @default(WAITING)
  winnerId   String? // The user ID of the winner

  startedAt DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamBattleSubmission {
  id        String   @id @default(uuid())

  teamBattle   TeamBattle @relation(fields: [teamBattleId], references: [id], onDelete: Cascade)
  teamBattleId String

  submittedBy   User   @relation(fields: [submittedById], references: [id])
  submittedById String

  code     String
  language String
  output   String?

  status SubmissionStatus @default(PENDING)

  createdAt DateTime @default(now())
}

// ============= SQUID GAME MODE =============

model SquidGame {
  id String @id @default(uuid())
  
  // Tournament info
  name String
  status SquidGameStatus @default(REGISTRATION)
  maxPlayers Int @default(50)
  
  // Round info
  currentRound Int @default(0)
  totalRounds Int @default(5)
  
  // Players
  participants SquidGameParticipant[]
  
  // Problems per round
  roundProblems SquidGameRound[]
  
  // Leaderboard snapshots
  leaderboardSnapshots SquidGameLeaderboard[]
  
  startedAt DateTime?
  completedAt DateTime?
  createdAt DateTime @default(now())
}

model SquidGameParticipant {
  id String @id @default(uuid())
  
  squidGame SquidGame @relation(fields: [squidGameId], references: [id], onDelete: Cascade)
  squidGameId String
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  
  // Elimination info
  roundsEliminated Int @default(0) // Rounds survived before elimination
  status String @default("ACTIVE") // ACTIVE, ELIMINATED, WINNER
  
  // Score tracking
  totalScore Int @default(0)
  roundScores Int[] @default([]) // Array of scores per round
  
  joinedAt DateTime @default(now())
  eliminatedAt DateTime?
  
  // Submissions and scores
  submissions SquidGameSubmission[]
  
  @@unique([squidGameId, userId])
}

model SquidGameRound {
  id String @id @default(uuid())
  
  squidGame SquidGame @relation(fields: [squidGameId], references: [id], onDelete: Cascade)
  squidGameId String
  
  roundNumber Int
  difficulty Difficulty
  
  problem Problem @relation(fields: [problemId], references: [id])
  problemId String
  
  // Round rules
  timeLimit Int // In seconds
  playersAtStart Int
  playersEliminated Int @default(0)
  
  startedAt DateTime?
  endedAt DateTime?
  
  submissions SquidGameSubmission[]
  
  @@unique([squidGameId, roundNumber])
}

model SquidGameSubmission {
  id String @id @default(uuid())
  
  round SquidGameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId String
  
  participant SquidGameParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  participantId String
  
  code String
  language String
  
  status SubmissionStatus
  score Int @default(0) // Points earned for this submission
  executionTimeMs Int?
  testCasesPassed Int @default(0)
  totalTestCases Int @default(0)
  
  submittedAt DateTime @default(now())
}

model SquidGameLeaderboard {
  id String @id @default(uuid())
  
  squidGame SquidGame @relation(fields: [squidGameId], references: [id], onDelete: Cascade)
  squidGameId String
  
  roundNumber Int
  playerRankings Json // JSON array of {userId, username, rank, score, status}
  
  snapshotAt DateTime @default(now())
  
  @@unique([squidGameId, roundNumber])
}

