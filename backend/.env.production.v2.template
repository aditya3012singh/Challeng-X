# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION - VERSION 2 (Distributed System)
# ============================================================================
# 
# SECURITY NOTICE:
# This is a TEMPLATE file. Copy to .env.production.v2 and fill with real values.
# NEVER commit .env.production.v2 to version control!
#
# ============================================================================

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=production
PORT=4000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string (Neon)
# IMPORTANT: Use AWS Secrets Manager in production
# Generate new password: https://console.neon.tech
DATABASE_URL="postgresql://username:PASSWORD_HERE@host.neon.tech/database?sslmode=require"

# ============================================================================
# JWT SECRETS
# ============================================================================
# IMPORTANT: Generate strong secrets (48+ characters)
# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET="GENERATE_WITH_openssl_rand_base64_48"
JWT_REFRESH_SECRET="GENERATE_WITH_openssl_rand_base64_48"

# ============================================================================
# REDIS CONFIGURATION (Event Bus + Queue)
# ============================================================================
# IMPORTANT: Generate strong password
# Generate: openssl rand -base64 32
REDIS_PASSWORD="GENERATE_WITH_openssl_rand_base64_32"
REDIS_URL="redis://:${REDIS_PASSWORD}@redis:6379"
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================================
# JUDGE SERVICE CONFIGURATION
# ============================================================================
JUDGE_SERVICE_URL=http://judge:3001
JUDGE_SERVICE_HOST=judge
JUDGE_SERVICE_PORT=3001
JUDGE_SERVICE_TIMEOUT=300000

# ============================================================================
# WORKER CONFIGURATION
# ============================================================================
WORKER_CONCURRENCY=10
WORKER_INSTANCES=1
WORKER_TIMEOUT=30000
WORKER_HEALTH_CHECK_INTERVAL=30000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# IMPORTANT: Update for production domains (NO localhost!)
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com
FRONTEND_URL=https://your-frontend.vercel.app

# ============================================================================
# AWS S3 CONFIGURATION (Test Cases Storage)
# ============================================================================
# IMPORTANT: Use AWS Secrets Manager in production
# Rotate credentials: Cloudflare R2 Dashboard
S3_REGION="auto"
S3_BUCKET_NAME="codearena-testcases"
S3_ACCESS_KEY_ID="GENERATE_NEW_KEY_IN_CLOUDFLARE"
S3_SECRET_ACCESS_KEY="GENERATE_NEW_SECRET_IN_CLOUDFLARE"
S3_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
S3_PUBLIC_URL="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com/profile"
S3_AVATAR_BUCKET="profile"

# ============================================================================
# OAUTH CONFIGURATION
# ============================================================================
# IMPORTANT: Use production callback URLs
# Google OAuth - Regenerate secret: https://console.cloud.google.com
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REGENERATE_IN_GOOGLE_CONSOLE
GOOGLE_CALLBACK_URL=https://api.your-domain.com/api/auth/google/callback

# GitHub OAuth - Regenerate secret: https://github.com/settings/developers
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REGENERATE_IN_GITHUB_SETTINGS
GITHUB_CALLBACK_URL=https://api.your-domain.com/api/auth/github/callback

# ============================================================================
# AI CONFIGURATION (Gemini API)
# ============================================================================
# IMPORTANT: Generate new key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=GENERATE_NEW_KEY_IN_GOOGLE_AI_STUDIO

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=info
REQUEST_LOGGING=true
ERROR_LOGGING=true

# ============================================================================
# HEALTH CHECK CONFIGURATION
# ============================================================================
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# ============================================================================
# MONITORING & METRICS
# ============================================================================
METRICS_ENABLED=true
METRICS_INTERVAL=60000

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
HTTPS_ONLY=true
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000

# ============================================================================
# RUNNER CONFIGURATION
# ============================================================================
CODEARENA_RUNNERS_PATH=/app/runners

# ============================================================================
# SECURITY CHECKLIST BEFORE DEPLOYMENT
# ============================================================================
# [ ] All secrets rotated (database, JWT, Redis, S3, OAuth, API keys)
# [ ] Strong passwords generated (32+ characters)
# [ ] No localhost URLs in CORS or OAuth callbacks
# [ ] .env.production.v2 added to .gitignore
# [ ] Secrets stored in AWS Secrets Manager (recommended)
# [ ] OAuth providers updated with production URLs
# [ ] SSL certificates generated
# [ ] All Docker images built
# [ ] Health checks tested
# ============================================================================
