# Server
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://codearena.live
# Comma-separated list of additional allowed origins
ALLOWED_ORIGINS=https://api.codearena.live,http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth
JWT_ACCESS_SECRET=your_super_secret_access_key_at_least_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS/Cloudflare S3/R2
S3_REGION=auto
S3_BUCKET_NAME=your_bucket
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://pub-<id>.r2.dev

# CodeArena# App Configs
CODEARENA_RUNNERS_PATH="./runners"
JUDGE_POOL_SIZE=10
MATCHMAKING_RANK_THRESHOLD=2000
WORKER_CONCURRENCY=10
